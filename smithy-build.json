{
  "version": "1.0",
  "sources": ["model"],
  "projections": {
    "openapi-auth-public": {
      "plugins": {
        "openapi": {
          "service": "com.minigithub.auth#AuthPublicApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-auth-account": {
      "plugins": {
        "openapi": {
          "service": "com.minigithub.auth#AuthAccountApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-repo": {
      "plugins": {
        "openapi": {
          "service": "com.minigithub.repo#RepoApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-issue": {
      "plugins": {
        "openapi": {
          "service": "com.minigithub.issue#IssueApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-issue-comments": {
      "plugins": {
        "openapi": {
          "service": "com.minigithub.issue#IssueCommentsApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-files": {
      "plugins": {
        "openapi": {
          "service": "com.minigithub.files#FilesApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-search": {
      "plugins": {
        "openapi": {
          "service": "com.minigithub.search#SearchApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    }
  }
}
