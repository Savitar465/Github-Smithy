{
  "version": "1.0",
  "sources": ["model"],
  "maven": {
    "dependencies": [
      "software.amazon.smithy:smithy-aws-traits:1.47.0",
      "software.amazon.smithy:smithy-aws-apigateway-traits:1.47.0"
    ]
  },
  "projections": {
    "openapi-auth-public": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.auth#AuthPublicApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-auth-account": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.auth#AuthAccountApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-repo": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.repo#RepoApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-issue": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.issue#IssueApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-issue-comments": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.issue#IssueCommentsApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-pullrequest": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.pullrequest#PullRequestApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-files": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.files#FilesApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-search": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.search#SearchApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-org-public": {
      "plugins": {
        "openapi": {
        "service": "com.githubx.organization#OrgPublicApi",
        "protocol": "aws.protocols#restJson1"
        }
      }
    },
    "openapi-org": {
      "plugins": {
        "openapi": {
          "service": "com.githubx.organization#OrgApi",
          "protocol": "aws.protocols#restJson1"
        }
      }
    }
  }
}
